{
  "format_version": "1.8.0",
  "animation_controllers": {
    "controller.animation.shapeshifter.phase_change": {
      "initial_state": "default",
      "states": {
        "default": {
          "animations": ["phase_change"],
          "transitions": [
            {
              "phase_changing": "query.sample:shapeshifter_angry==true"
            }
          ]
        },
        "phase_changing": {
          "animations": ["phase_change"],
          "sound_effects": [
            {
              "effect": "phase_change"
            }
          ],
          "transitions": [
            {
              "default": "query.sample:shapeshifter_angry==false"
            }
          ],
          "blend_transition": 0.2
        }
      }
    }
  }
}
